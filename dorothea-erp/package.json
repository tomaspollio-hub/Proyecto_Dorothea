{
  "name": "dorothea-erp",
  "private": true,
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "typecheck": "pnpm -r typecheck",
    "migrate:local": "wrangler d1 migrations apply dorothea-db --local",
    "migrate:remote": "wrangler d1 migrations apply dorothea-db --remote",
    "seed:local": "tsx scripts/seed.ts --local",
    "import:legacy": "tsx scripts/import-legacy.ts",
    "import:customers-legacy": "tsx scripts/import-customers-legacy.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "wrangler": "^3.80.0"
  }
}
