# Variables de entorno para desarrollo local
# Copiar como .env y completar los valores

# JWT
JWT_SECRET=cambia-esto-por-un-secret-largo-y-aleatorio

# Cloudflare (se configura en wrangler.toml para Workers)
# Estos valores son solo para scripts locales (migrate, seed)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
